src/
 ├── app/                 # Конфигурация приложения (Redux Store, маршрутизация)
 │   ├── store.ts         # Redux Toolkit store
 │   ├── rootReducer.ts   # Комбинированные редьюсеры
 │   ├── providers/       # Провайдеры (ThemeProvider, RouterProvider)
 │   └── api/             # Общая настройка API (baseQuery)
 │
 ├── pages/               # Страницы (роуты)
 │   ├── Home/            # Главная страница
 │   ├── CoursePage/      # Страница курса
 │   ├── NotFound/        # 404
 │   └── index.ts         # Экспорт всех страниц
 │
 ├── widgets/             # Крупные независимые компоненты (модалки, хедер, футер)
 │   ├── Header/          # Шапка
 │   ├── Footer/          # Подвал
 │   ├── CourseList/      # Список курсов
 │   ├── CourseCard/      # Карточка курса
 │   ├── Modal/           # Универсальная модалка
 │   ├── index.ts         # Экспорт виджетов
 │
 ├── features/            # Бизнес-логика (редакс-слайсы, хуки)
 │   ├── courses/         # Управление курсами
 │   │   ├── api.ts       # Запросы по курсам через React Query / RTK Query
 │   │   ├── slice.ts     # Redux Slice для курсов
 │   │   ├── selectors.ts # Селекторы курсов
 │   │   └── index.ts     # Экспорт
 │   ├── discounts/       # Управление скидками
 │   ├── news/            # Новости
 │   ├── user/            # В будущем - пользователь
 │   └── index.ts         # Экспорт фич
 │
 ├── entities/            # Отдельные бизнес-сущности (курс, скидка, пользователь)
 │   ├── Course/          # Компонент + типы для курса
 │   ├── Discount/        # Компонент + логика скидок
 │   ├── News/            # Компонент + логика новостей
 │   ├── index.ts         # Экспорт сущностей
 │
 ├── shared/              # Общие компоненты, стили, утилиты
 │   ├── ui/              # UI-компоненты (кнопки, инпуты, карточки)
 │   ├── lib/             # Хелперы, утилиты
 │   ├── styles/          # Глобальные стили, тема MUI
 │   ├── api/             # Конфигурация запросов (RTK Query / React Query)
 │   └── config.ts        # Конфигурации (константы, env)
 │
 ├── index.tsx            # Точка входа
 └── package.json
