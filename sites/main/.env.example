# ============================================================
# MY COMPUTER ACADEMY — .env
# Скопируй в .env и заполни ПЕРЕД деплоем
# НИКОГДА не коммить .env в git!
# ============================================================

# Порт (Hostinger VPS: оставь 3000, Nginx будет проксировать)
PORT=3000

# ОБЯЗАТЕЛЬНО: замени на длинный случайный токен!
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ТОКЕН_МИНИМУМ_32_СИМВОЛА

# Разрешённый origin (твой домен без trailing slash)
# На продакшне: ALLOWED_ORIGIN=https://mycomputer.education
# Для теста: ALLOWED_ORIGIN=*
ALLOWED_ORIGIN=https://mycomputer.education

# ============================================================
# EMAIL УВЕДОМЛЕНИЯ (nodemailer + Gmail)
# ============================================================
# Инструкция по настройке Gmail App Password:
#   1. Войдите в аккаунт Google (my.computer.academy25@gmail.com)
#   2. Включите 2-факторную аутентификацию:
#      myaccount.google.com → Безопасность → Двухэтапная аутентификация
#   3. Создайте App Password:
#      myaccount.google.com → Безопасность → Пароли приложений
#      Выберите "Почта" → "Другое устройство" → назовите "MCA Landing"
#   4. Скопируйте 16-символьный код (без пробелов) → вставьте как SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Ваш Gmail-адрес отправителя
SMTP_USER=my.computer.academy25@gmail.com

# 16-символьный App Password (НЕ обычный пароль!)
SMTP_PASS=ВСТАВЬТЕ_APP_PASSWORD_БЕЗ_ПРОБЕЛОВ

# Куда получать уведомления о заявках
NOTIFY_EMAIL=my.computer.academy25@gmail.com
